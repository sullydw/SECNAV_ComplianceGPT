{
  "schema_version": "CCI_INTAKE_QUESTIONS_V1",
  "description": "Deterministic intake question definitions for SECNAV correspondence. Filtered by doc_type and component. Consumed by IntakeOrchestrator.next_questions().",
  "questions": [
    {
      "question_id": "q_doc_type",
      "field_path": "doc_type",
      "prompt_text": "What type of correspondence is this? (e.g., standard_letter, endorsement, joint_letter, memorandum_for_record, from_to_memo)",
      "importance": "required",
      "applies_to_doc_types": [],
      "applies_to_component": [],
      "data_type": "choice",
      "choices": ["standard_letter", "multiple_address_letter", "endorsement", "joint_letter", "memorandum_for_record", "from_to_memo", "plain_paper_memo", "decision_memo"],
      "aliases": ["type", "correspondence_type"]
    },
    {
      "question_id": "q_component_service",
      "field_path": "component.service",
      "prompt_text": "Which service or component is this correspondence from? (navy, marine_corps, joint, don_secretariat)",
      "importance": "required",
      "applies_to_doc_types": [],
      "applies_to_component": [],
      "data_type": "choice",
      "choices": ["navy", "marine_corps", "joint", "don_secretariat"],
      "aliases": ["service", "component"]
    },
    {
      "question_id": "q_from",
      "field_path": "from",
