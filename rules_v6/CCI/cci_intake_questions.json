      "importance": "required",
      "applies_to_doc_types": ["standard_letter", "multiple_address_letter", "endorsement", "joint_letter", "from_to_memo", "plain_paper_memo", "decision_memo"],
      "applies_to_component": [],
      "data_type": "string",
      "choices": null,
      "aliases": ["sender", "from_line"]
    },
